# ==============================================
# 4ortin-X Environment Variables
# ==============================================
# SECURITY NOTE: Variables prefixed with VITE_ are bundled into the
# client JavaScript and visible to anyone who inspects the page source.
# NEVER put API secrets or private keys in VITE_ prefixed variables.
# ==============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# WalletConnect Project ID (for Web3 wallet connections)
# This is a public ID, safe to expose
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Fee Wallet Address (receives swap fees from 1inch)
# This is a public address, safe to expose
VITE_FEE_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f5bE21

# 1inch API Key (get from https://portal.1inch.dev)
# Required for swap functionality - this is a public API key
VITE_1INCH_API_KEY=your_1inch_api_key_here

# Backend API URL
VITE_API_URL=https://your-backend.herokuapp.com/api

# MoonPay Public Key (get from https://dashboard.moonpay.com)
# Only the PUBLIC key should be exposed client-side
VITE_MOONPAY_API_KEY=pk_live_your_api_key

# Transak Public API Key (optional)
VITE_TRANSAK_API_KEY=your_transak_api_key

# ==============================================
# Server-Side Only (Vercel Environment Variables)
# ==============================================
# IMPORTANT: Set these in Vercel dashboard, NOT in .env files!
# These should NEVER have the VITE_ prefix.
# - SUPABASE_URL
# - SUPABASE_SERVICE_ROLE_KEY
# - RESEND_API_KEY
# - COINBASE_API_KEY (if used server-side)
# - COINBASE_API_SECRET
# - BINANCE_API_KEY (if used server-side)
# - BINANCE_API_SECRET
# - MOONPAY_SECRET_KEY
# ==============================================
