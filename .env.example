# Coinbase Advanced Trade API Credentials
# Get these from: https://www.coinbase.com/settings/api
# Create an API key with "Trade" permissions for live trading
VITE_COINBASE_API_KEY=your_api_key_here
VITE_COINBASE_API_SECRET=your_api_secret_here

# Supabase Configuration (existing)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# WalletConnect Project ID (for Web3 wallet connections)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Fee Wallet Address
VITE_FEE_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f5bE21

# Backend API URL
VITE_API_URL=https://your-backend.herokuapp.com/api

# MoonPay Integration (get keys from https://dashboard.moonpay.com)
VITE_MOONPAY_API_KEY=pk_live_your_api_key
VITE_MOONPAY_SECRET_KEY=sk_live_your_secret_key

# Transak Integration (optional)
VITE_TRANSAK_API_KEY=your_transak_api_key
