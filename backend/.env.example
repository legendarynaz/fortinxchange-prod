# Server Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_PATH=./data/fortinx.db

# JWT Secret for Admin Auth
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Fee Wallet Address (your wallet to receive fees)
FEE_WALLET_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f5bE21

# RPC URLs for blockchain monitoring
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed1.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# Fee Configuration
SWAP_FEE_PERCENT=0.5
ONRAMP_COMMISSION_PERCENT=0.5
BRIDGE_FEE_PERCENT=0.1

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,https://14digitalxchange.com

# Rate Limiting
RATE_LIMIT_POINTS=100
RATE_LIMIT_DURATION=60

# Webhook Secrets (optional)
MOONPAY_WEBHOOK_SECRET=
TRANSAK_WEBHOOK_SECRET=
WEBHOOK_API_KEY=your-webhook-api-key

# API Key for service-to-service calls
API_KEY=your-api-key-for-services
